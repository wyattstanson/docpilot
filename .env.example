# DocPilot environment — copy this file to ".env" and uncomment ONE recipe.
# .env is gitignored and never committed.
#
# DocPilot's OpenAI client can point at any OpenAI-compatible endpoint, so the
# free providers below (Groq, Gemini) work with no code changes.

# ─────────────────────────────────────────────────────────────────────────────
# RECIPE A — Groq  (FREE, no billing, real LLM, instant signup)
# Get a key at https://console.groq.com/keys  (starts with "gsk_")
# Groq has no embeddings, so the link graph uses mock embeddings — fine for demos.
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=gsk_your_groq_key_here
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# DOCPILOT_LLM_MODEL=llama-3.3-70b-versatile
# DOCPILOT_EMBEDDING_PROVIDER=mock

# ─────────────────────────────────────────────────────────────────────────────
# RECIPE B — Google Gemini  (FREE tier, real LLM *and* embeddings)
# Get a key at https://aistudio.google.com/apikey  (starts with "AIza")
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=AIza_your_gemini_key_here
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# DOCPILOT_LLM_MODEL=gemini-2.0-flash
# DOCPILOT_EMBEDDING_MODEL=text-embedding-004

# ─────────────────────────────────────────────────────────────────────────────
# RECIPE C — OpenAI  (paid; one key does GPT-4o + embeddings)
# Get a key at https://platform.openai.com/api-keys  (starts with "sk-")
# ─────────────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-openai-key-here

# ─────────────────────────────────────────────────────────────────────────────
# RECIPE D — Anthropic Claude  (LLM only; embeddings need an OpenAI key too)
# Get a key at https://console.anthropic.com/  (starts with "sk-ant-")
# ─────────────────────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# DOCPILOT_LLM_PROVIDER=anthropic

